// AssetFlow — Phase 1 schema
// Only the User model exists at this stage (auth + role foundation).
// Later phases will add Department, AssetCategory, Asset, Allocation,
// TransferRequest, Booking, MaintenanceRequest, AuditCycle, Notification, etc.

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  EMPLOYEE
  DEPARTMENT_HEAD
  ASSET_MANAGER
  ADMIN
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

model User {
  id               String     @id @default(uuid())
  name             String
  email            String     @unique
  passwordHash     String
  role             Role       @default(EMPLOYEE)
  status           UserStatus @default(ACTIVE)

  // forgot-password flow
  resetToken       String?
  resetTokenExpiry DateTime?

  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  @@map("users")
}
