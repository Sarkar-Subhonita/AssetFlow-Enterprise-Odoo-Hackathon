// AssetFlow — Phase 2 schema
// Extends the Phase 1 User model with Department, AssetCategory, Asset,
// Allocation, TransferRequest, Booking, MaintenanceRequest, AuditCycle,
// AuditItem, Notification, and ActivityLog.
//
// Conventions carried over from Phase 1:
//   - all ids are String @id @default(uuid())
//   - enum values are UPPER_CASE
//   - no per-field @map (camelCase columns as-is)
//   - table names use @@map("plural_snake_case")

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ------------------------------------------------------------
// ENUMS
// ------------------------------------------------------------

enum Role {
  EMPLOYEE
  DEPARTMENT_HEAD
  ASSET_MANAGER
  ADMIN
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum DepartmentStatus {
  ACTIVE
  INACTIVE
}

enum AssetStatus {
  AVAILABLE
  ALLOCATED
  RESERVED
  UNDER_MAINTENANCE
  LOST
  RETIRED
  DISPOSED
}

enum AllocationStatus {
  ACTIVE
  RETURNED
}

enum TransferStatus {
  REQUESTED
  APPROVED
  REJECTED
  COMPLETED
}

enum BookingStatus {
  UPCOMING
  ONGOING
  COMPLETED
  CANCELLED
}

enum MaintenancePriority {
  LOW
  MEDIUM
  HIGH
}

enum MaintenanceStatus {
  PENDING
  APPROVED
  REJECTED
  TECHNICIAN_ASSIGNED
  IN_PROGRESS
  RESOLVED
}

enum AuditCycleStatus {
  OPEN
  CLOSED
}

enum AuditVerification {
  PENDING
  VERIFIED
  MISSING
  DAMAGED
}

// ------------------------------------------------------------
// USERS  (Phase 1 model — extended, not replaced)
// ------------------------------------------------------------

model User {
  id               String     @id @default(uuid())
  name             String
  email            String     @unique
  passwordHash     String
  role             Role       @default(EMPLOYEE)
  status           UserStatus @default(ACTIVE)

  // forgot-password flow
  resetToken       String?
  resetTokenExpiry DateTime?

  // new in Phase 2
  departmentId     String?
  department       Department? @relation("DepartmentMembers", fields: [departmentId], references: [id])

  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  // Reverse relations
  headOfDepartments  Department[]         @relation("DepartmentHead")
  currentAssets      Asset[]              @relation("AssetCurrentHolder")
  allocations        Allocation[]         @relation("AllocationEmployee")
  transfersFrom      TransferRequest[]    @relation("TransferFromUser")
  transfersTo        TransferRequest[]    @relation("TransferToUser")
  transfersApproved  TransferRequest[]    @relation("TransferApprovedBy")
  bookings           Booking[]            @relation("BookingBookedBy")
  maintenanceRaised  MaintenanceRequest[] @relation("MaintenanceRaisedBy")
  auditItemsAssigned AuditItem[]          @relation("AuditItemAuditor")
  notifications      Notification[]       @relation("NotificationUser")
  activityLogs       ActivityLog[]        @relation("ActivityLogUser")

  @@map("users")
}

// ------------------------------------------------------------
// DEPARTMENTS (self-referencing hierarchy)
// ------------------------------------------------------------

model Department {
  id     String           @id @default(uuid())
  name   String
  status DepartmentStatus @default(ACTIVE)

  headUserId String?
  head       User?   @relation("DepartmentHead", fields: [headUserId], references: [id])

  parentDepartmentId String?
  parent             Department?  @relation("DepartmentHierarchy", fields: [parentDepartmentId], references: [id])
  children           Department[] @relation("DepartmentHierarchy")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Reverse relations
  members       User[]       @relation("DepartmentMembers")
  currentAssets Asset[]      @relation("AssetCurrentDepartment")
  allocations   Allocation[] @relation("AllocationDepartment")
  bookings      Booking[]    @relation("BookingDepartment")
  auditCycles   AuditCycle[] @relation("AuditCycleScopeDepartment")

  @@map("departments")
}

// ------------------------------------------------------------
// ASSET CATEGORIES
// ------------------------------------------------------------

model AssetCategory {
  id           String @id @default(uuid())
  name         String
  customFields Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assets Asset[] @relation("AssetCategory")

  @@map("asset_categories")
}

// ------------------------------------------------------------
// ASSETS
// ------------------------------------------------------------

model Asset {
  id              String      @id @default(uuid())
  assetTag        String      @unique // AF-0001
  name            String
  serialNumber    String?
  acquisitionDate DateTime?
  acquisitionCost Decimal?    @db.Decimal(12, 2)
  condition       String      @default("Good")
  location        String?
  isBookable      Boolean     @default(false)
  status          AssetStatus @default(AVAILABLE)

  categoryId String
  category   AssetCategory @relation("AssetCategory", fields: [categoryId], references: [id])

  currentHolderUserId String?
  currentHolderUser   User?   @relation("AssetCurrentHolder", fields: [currentHolderUserId], references: [id])

  currentHolderDepartmentId String?
  currentHolderDepartment   Department? @relation("AssetCurrentDepartment", fields: [currentHolderDepartmentId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Reverse relations — full lifecycle history lives here
  allocations         Allocation[]         @relation("AllocationAsset")
  transferRequests    TransferRequest[]    @relation("TransferAsset")
  bookings            Booking[]            @relation("BookingAsset")
  maintenanceRequests MaintenanceRequest[] @relation("MaintenanceAsset")
  auditItems          AuditItem[]          @relation("AuditItemAsset")

  @@index([status])
  @@index([categoryId])
  @@map("assets")
}

// ------------------------------------------------------------
// ALLOCATIONS
// ------------------------------------------------------------

model Allocation {
  id String @id @default(uuid())

  assetId String
  asset   Asset  @relation("AllocationAsset", fields: [assetId], references: [id])

  employeeId String
  employee   User   @relation("AllocationEmployee", fields: [employeeId], references: [id])

  departmentId String?
  department   Department? @relation("AllocationDepartment", fields: [departmentId], references: [id])

  allocatedAt          DateTime          @default(now())
  expectedReturnDate   DateTime?
  returnedAt           DateTime?
  returnConditionNotes String?
  status               AllocationStatus  @default(ACTIVE)

  @@index([assetId, status])
  @@index([employeeId])
  @@map("allocations")
}

// ------------------------------------------------------------
// TRANSFER REQUESTS
// ------------------------------------------------------------

model TransferRequest {
  id String @id @default(uuid())

  assetId String
  asset   Asset  @relation("TransferAsset", fields: [assetId], references: [id])

  fromUserId String
  fromUser   User   @relation("TransferFromUser", fields: [fromUserId], references: [id])

  toUserId String
  toUser   User   @relation("TransferToUser", fields: [toUserId], references: [id])

  requestedAt DateTime       @default(now())
  status      TransferStatus @default(REQUESTED)

  approvedByUserId String?
  approvedByUser   User?   @relation("TransferApprovedBy", fields: [approvedByUserId], references: [id])

  @@index([assetId, status])
  @@map("transfer_requests")
}

// ------------------------------------------------------------
// BOOKINGS
// ------------------------------------------------------------

model Booking {
  id String @id @default(uuid())

  assetId String
  asset   Asset  @relation("BookingAsset", fields: [assetId], references: [id])

  bookedByUserId String
  bookedByUser   User   @relation("BookingBookedBy", fields: [bookedByUserId], references: [id])

  departmentId String?
  department   Department? @relation("BookingDepartment", fields: [departmentId], references: [id])

  startTime DateTime
  endTime   DateTime
  status    BookingStatus @default(UPCOMING)

  createdAt DateTime @default(now())

  // Overlap validation (assetId + time range) is enforced in the service/repository
  // layer, not the DB — Postgres needs the btree_gist extension for a true exclusion
  // constraint. This index just keeps the overlap lookup query fast.
  @@index([assetId, startTime, endTime])
  @@map("bookings")
}

// ------------------------------------------------------------
// MAINTENANCE REQUESTS
// ------------------------------------------------------------

model MaintenanceRequest {
  id String @id @default(uuid())

  assetId String
  asset   Asset  @relation("MaintenanceAsset", fields: [assetId], references: [id])

  raisedByUserId String
  raisedByUser   User   @relation("MaintenanceRaisedBy", fields: [raisedByUserId], references: [id])

  issueDescription String
  priority         MaintenancePriority @default(MEDIUM)
  status           MaintenanceStatus   @default(PENDING)
  technicianName   String?

  createdAt  DateTime  @default(now())
  resolvedAt DateTime?

  @@index([assetId])
  @@index([status])
  @@map("maintenance_requests")
}

// ------------------------------------------------------------
// AUDIT CYCLES + ITEMS
// ------------------------------------------------------------

model AuditCycle {
  id   String @id @default(uuid())
  name String

  scopeDepartmentId String?
  scopeDepartment   Department? @relation("AuditCycleScopeDepartment", fields: [scopeDepartmentId], references: [id])

  startDate DateTime
  endDate   DateTime
  status    AuditCycleStatus @default(OPEN)

  createdAt DateTime @default(now())

  auditItems AuditItem[] @relation("AuditCycleItems")

  @@map("audit_cycles")
}

model AuditItem {
  id String @id @default(uuid())

  auditCycleId String
  auditCycle   AuditCycle @relation("AuditCycleItems", fields: [auditCycleId], references: [id])

  assetId String
  asset   Asset  @relation("AuditItemAsset", fields: [assetId], references: [id])

  auditorUserId String
  auditorUser   User   @relation("AuditItemAuditor", fields: [auditorUserId], references: [id])

  verificationStatus AuditVerification @default(PENDING)

  @@index([auditCycleId])
  @@map("audit_items")
}

// ------------------------------------------------------------
// NOTIFICATIONS
// ------------------------------------------------------------

model Notification {
  id String @id @default(uuid())

  userId String
  user   User   @relation("NotificationUser", fields: [userId], references: [id])

  message   String
  type      String   // e.g. "ASSET_ASSIGNED" | "MAINTENANCE_APPROVED" | "BOOKING_CONFIRMED" | "TRANSFER_APPROVED" | "OVERDUE_RETURN"
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, isRead])
  @@map("notifications")
}

// ------------------------------------------------------------
// ACTIVITY LOGS (feature 19 — full admin/manager/employee audit trail)
// ------------------------------------------------------------

model ActivityLog {
  id String @id @default(uuid())

  userId String
  user   User   @relation("ActivityLogUser", fields: [userId], references: [id])

  action     String // e.g. "ASSET_REGISTER", "ALLOCATION_CREATE", "TRANSFER_APPROVE"
  entityType String // e.g. "Asset", "Booking", "MaintenanceRequest"
  entityId   String?
  metadata   Json?  // free-form details (before/after values, reason, etc.)

  createdAt DateTime @default(now())

  @@index([entityType, entityId])
  @@index([userId])
  @@map("activity_logs")
}
